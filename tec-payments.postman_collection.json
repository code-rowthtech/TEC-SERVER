{
  "info": {
    "name": "TEC Payments",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "providerId", "value": "" },
    { "key": "transactionId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) pm.collectionVariables.set('token', res.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Providers",
      "item": [
        {
          "name": "Get Providers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/providers",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Provider",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/providers/{{providerId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Onboarding Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/providers/{{providerId}}/onboarding-status",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Onboard Provider",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/providers/onboard",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tebra_provider_id\": \"tebra-123\",\n  \"npi\": \"1234567890\",\n  \"name\": \"Dr. Jane Smith\",\n  \"email\": \"provider@example.com\"\n}"
            }
          }
        },
        {
          "name": "Update Split",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/providers/{{providerId}}/split",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"split_percentage\": 80\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Get Transactions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/payments?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments"],
              "query": [
                { "key": "provider", "value": "", "disabled": true },
                { "key": "status", "value": "", "disabled": true },
                { "key": "from", "value": "", "disabled": true },
                { "key": "to", "value": "", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Transaction",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/payments/{{transactionId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Charge",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/charge",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider_id\": \"{{providerId}}\",\n  \"amount\": 5000,\n  \"payment_method_id\": \"pm_card_visa\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Payouts",
      "item": [
        {
          "name": "Get Payouts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/payouts?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payouts"],
              "query": [
                { "key": "provider", "value": "", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Trigger Instant Payout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/payouts/instant/{{providerId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 10000\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reconciliation",
      "item": [
        {
          "name": "Get Summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reconciliation/summary",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Provider Ledger",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reconciliation/provider/{{providerId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Webhook",
      "item": [
        {
          "name": "Stripe Webhook",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/webhook",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "stripe-signature", "value": "<stripe_signature>" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_test_123\",\n  \"type\": \"payment_intent.succeeded\",\n  \"data\": {\n    \"object\": {}\n  }\n}"
            }
          }
        }
      ]
    }
  ]
}
